{
  "info": {
    "_postman_id": "00000000-0000-0000-0000-000000000001",
    "name": "Example API",
    "description": "Colección de ejemplo — reemplazá con tu API real usando /postman:generate",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Health",
      "item": [
        {
          "name": "Health Check",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('status is 200', () => pm.response.to.have.status(200));",
            "pm.test('response time < 500ms', () => pm.expect(pm.response.responseTime).to.be.below(500));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "02 - Resources — Happy Path",
      "item": [
        {
          "name": "GET /resources — listar",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('status is 200', () => pm.response.to.have.status(200));",
            "pm.test('response is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/resources", "host": ["{{baseUrl}}"], "path": ["resources"] }
          }
        },
        {
          "name": "POST /resources — crear",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('status is 201', () => pm.response.to.have.status(201));",
            "const json = pm.response.json();",
            "pm.test('body has id', () => pm.expect(json).to.have.property('id'));",
            "pm.environment.set('resourceId', json.id);"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Ejemplo\",\n  \"description\": \"Recurso de ejemplo\"\n}" },
            "url": { "raw": "{{baseUrl}}/resources", "host": ["{{baseUrl}}"], "path": ["resources"] }
          }
        },
        {
          "name": "DELETE /resources/:id — eliminar",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('status is 204', () => pm.response.to.have.status(204));",
            "pm.environment.unset('resourceId');"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "DELETE", "header": [],
            "url": { "raw": "{{baseUrl}}/resources/{{resourceId}}", "host": ["{{baseUrl}}"], "path": ["resources", "{{resourceId}}"] }
          }
        }
      ]
    },
    {
      "name": "03 - Validaciones",
      "item": [
        {
          "name": "POST — body vacío → 400",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('status is 400', () => pm.response.to.have.status(400));",
            "pm.test('errors present', () => pm.expect(pm.response.json()).to.have.property('errors'));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{baseUrl}}/resources", "host": ["{{baseUrl}}"], "path": ["resources"] }
          }
        }
      ]
    }
  ]
}
